generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Institution {
  id               String   @id @default(cuid())
  name             String
  address          String?
  phone            String?
  logo             String?
  subscriptionPlan String   @default("FREE") // FREE, BASIC, PREMIUM
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users     User[]
  students  Student[]
  teachers  Teacher[]
  sessions  Session[]
  invoices  Invoice[]
  reports   Report[]
  subjects  Subject[]
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  password     String
  role         String   @default("DIRECTOR") // DIRECTOR, TEACHER, PARENT
  institutionId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  notifications Notification[]
  teacher       Teacher?
  parent        Parent?
}

model Subject {
  id            String @id @default(cuid())
  name          String
  level         String // ابتدائي, متوسط, ثانوي
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
  sessions    Session[]
  teachers    TeacherSubject[]
  pricing     Pricing[]
}

model Student {
  id            String   @id @default(cuid())
  name          String
  level         String
  parentId      String?
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  parent      Parent?     @relation(fields: [parentId], references: [id])
  absences    Absence[]
  invoices    Invoice[]
  attendances Attendance[]
}

model Parent {
  id        String @id @default(cuid())
  userId    String @unique
  phone     String?

  user     User     @relation(fields: [userId], references: [id])
  students Student[]
}

model Teacher {
  id            String @id @default(cuid())
  userId        String @unique
  institutionId String

  user        User             @relation(fields: [userId], references: [id])
  institution Institution      @relation(fields: [institutionId], references: [id])
  subjects    TeacherSubject[]
  sessions    Session[]
  absences    Absence[]
}

model TeacherSubject {
  id        String @id @default(cuid())
  teacherId String
  subjectId String

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([teacherId, subjectId])
}

model Session {
  id            String   @id @default(cuid())
  subjectId     String
  teacherId     String
  institutionId String
  dayOfWeek     Int      // 0=Sunday, 1=Monday... 6=Saturday
  startTime     String   // "08:00"
  endTime       String   // "09:00"
  date          DateTime?
  status        String   @default("SCHEDULED") // SCHEDULED, DONE, CANCELLED, COMPENSATED
  level         String
  repeatType    String   @default("WEEKLY") // WEEKLY, EXCEPTIONAL
  cancelReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subject     Subject     @relation(fields: [subjectId], references: [id])
  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  institution Institution @relation(fields: [institutionId], references: [id])
  absences    Absence[]
  attendances Attendance[]
}

model Absence {
  id              String   @id @default(cuid())
  studentId       String?
  teacherId       String?
  sessionId       String
  reason          String?
  absenceType     String   @default("STUDENT") // STUDENT, TEACHER
  notificationSent Boolean @default(false)
  createdAt       DateTime @default(now())

  student Student? @relation(fields: [studentId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])
  session  Session  @relation(fields: [sessionId], references: [id])
}

model Attendance {
  id        String @id @default(cuid())
  studentId String
  sessionId String
  status    String @default("PRESENT") // PRESENT, ABSENT, LATE
  note      String?
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  session  Session @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId])
}

model Invoice {
  id                String   @id @default(cuid())
  studentId         String
  institutionId     String
  month             Int
  year              Int
  totalSessions     Int      @default(0)
  absentSessions    Int      @default(0)
  compensatedSessions Int    @default(0)
  amount            Float    @default(0)
  status            String   @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt            DateTime?
  paymentMethod     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student     Student           @relation(fields: [studentId], references: [id])
  institution Institution       @relation(fields: [institutionId], references: [id])
  lineItems   InvoiceLineItem[]
}

model InvoiceLineItem {
  id              String  @id @default(cuid())
  invoiceId       String
  subjectName     String
  totalSessions   Int     @default(0)
  absentSessions  Int     @default(0)
  pricePerSession Float   @default(0)
  subtotal        Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  message   String
  type      String   // ABSENCE, CANCELLATION, INVOICE, GENERAL
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id            String   @id @default(cuid())
  institutionId String
  type          String   // DAILY, MONTHLY
  data          String   // JSON string
  generatedAt   DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
}

model Pricing {
  id            String @id @default(cuid())
  subjectId     String
  level         String
  pricePerSession Float @default(0)
  institutionId String

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}
