generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Institution {
  id               String   @id @default(cuid())
  name             String
  address          String?
  phone            String?
  logo             String?
  subscriptionPlan String   @default("FREE") // FREE, BASIC, PREMIUM
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  users     User[]
  students  Student[]
  teachers  Teacher[]
  sessions  Session[]
  invoices  Invoice[]
  reports   Report[]
  subjects  Subject[]
  years     Year[]
  sections  Section[]
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          String   @default("DIRECTOR") // DIRECTOR, TEACHER, PARENT
  institutionId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution   Institution @relation(fields: [institutionId], references: [id])
  notifications Notification[]
  teacher       Teacher?
  parent        Parent?
}

model Subject {
  id            String @id @default(cuid())
  name          String
  level         String // ابتدائي, متوسط, ثانوي
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
  sessions    Session[]
  pricing     Pricing[]
  teachers    Teacher[]
}

model Year {
  id            String @id @default(cuid())
  name          String // e.g. "السنة الأولى متوسط"
  level         String // ابتدائي, متوسط, ثانوي
  order         Int    // 1, 2, 3, 4, 5
  institutionId String
  createdAt     DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
  sections    Section[]
}

model Section {
  id            String @id @default(cuid())
  name          String // e.g. "قسم أ", "علوم تجريبية"
  yearId        String
  institutionId String
  capacity      Int    @default(30)
  supervisorId  String? // Teacher who supervises this section
  createdAt     DateTime @default(now())

  year        Year     @relation(fields: [yearId], references: [id], onDelete: Cascade)
  institution Institution @relation(fields: [institutionId], references: [id])
  supervisor  Teacher? @relation(fields: [supervisorId], references: [id])
  students    Student[]
  sessions    Session[]
  activities  StudentActivity[]
}

model Student {
  id            String   @id @default(cuid())
  name          String
  level         String   // ابتدائي, متوسط, ثانوي (denormalized for convenience)
  parentId      String?
  institutionId String
  sectionId     String?  // Link to section
  dateOfBirth   DateTime?
  gender        String?  // ذكر / أنثى
  phone         String?
  address       String?
  enrollmentDate DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  parent      Parent?     @relation(fields: [parentId], references: [id])
  section     Section?    @relation(fields: [sectionId], references: [id])
  absences    Absence[]
  invoices    Invoice[]
  attendances Attendance[]
  activities  StudentActivity[]
}

model Parent {
  id        String @id @default(cuid())
  userId    String @unique
  phone     String?

  user     User     @relation(fields: [userId], references: [id])
  students Student[]
}

model Teacher {
  id            String @id @default(cuid())
  userId        String @unique
  institutionId String
  level         String // الطور: ابتدائي, متوسط, ثانوي
  subjectId     String // ONE subject only - each teacher teaches one subject
  phone         String?
  specialization String? // e.g. "رياضيات متقدمة"

  user        User             @relation(fields: [userId], references: [id])
  institution Institution      @relation(fields: [institutionId], references: [id])
  subject     Subject          @relation(fields: [subjectId], references: [id])
  sessions    Session[]
  absences    Absence[]
  supervisedSections Section[]
  activities  StudentActivity[]
}

model Session {
  id            String   @id @default(cuid())
  subjectId     String
  teacherId     String
  institutionId String
  sectionId     String?  // Link to section for timetable
  dayOfWeek     Int      // 0=Sunday, 1=Monday... 6=Saturday
  startTime     String   // "08:00"
  endTime       String   // "09:00"
  date          DateTime?
  status        String   @default("SCHEDULED") // SCHEDULED, DONE, CANCELLED, COMPENSATED
  level         String
  repeatType    String   @default("WEEKLY") // WEEKLY, EXCEPTIONAL
  cancelReason  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subject     Subject         @relation(fields: [subjectId], references: [id])
  teacher     Teacher         @relation(fields: [teacherId], references: [id])
  institution Institution     @relation(fields: [institutionId], references: [id])
  section     Section?        @relation(fields: [sectionId], references: [id])
  absences    Absence[]
  attendances Attendance[]
  activities  StudentActivity[]
}

model Absence {
  id              String   @id @default(cuid())
  studentId       String?
  teacherId       String?
  sessionId       String
  reason          String?
  absenceType     String   @default("STUDENT") // STUDENT, TEACHER
  notificationSent Boolean @default(false)
  createdAt       DateTime @default(now())

  student Student? @relation(fields: [studentId], references: [id])
  teacher Teacher? @relation(fields: [teacherId], references: [id])
  session  Session  @relation(fields: [sessionId], references: [id])
}

model Attendance {
  id        String @id @default(cuid())
  studentId String
  sessionId String
  status    String @default("PRESENT") // PRESENT, ABSENT, LATE
  note      String?
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  session  Session  @relation(fields: [sessionId], references: [id])

  @@unique([studentId, sessionId])
}

model StudentActivity {
  id          String   @id @default(cuid())
  studentId   String
  teacherId   String
  sessionId   String?
  sectionId   String
  type        String   // HOMEWORK, EXAM, QUIZ, PARTICIPATION, BEHAVIOR, NOTE
  title       String
  description String?
  grade       Float?
  maxGrade    Float?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id])
  teacher  Teacher  @relation(fields: [teacherId], references: [id])
  session  Session? @relation(fields: [sessionId], references: [id])
  section  Section  @relation(fields: [sectionId], references: [id])
}

model Invoice {
  id                String   @id @default(cuid())
  studentId         String
  institutionId     String
  month             Int
  year              Int
  totalSessions     Int      @default(0)
  absentSessions    Int      @default(0)
  compensatedSessions Int    @default(0)
  amount            Float    @default(0)
  status            String   @default("PENDING") // PENDING, PAID, OVERDUE
  paidAt            DateTime?
  paymentMethod     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  student     Student           @relation(fields: [studentId], references: [id])
  institution Institution       @relation(fields: [institutionId], references: [id])
  lineItems   InvoiceLineItem[]
}

model InvoiceLineItem {
  id              String  @id @default(cuid())
  invoiceId       String
  subjectName     String
  totalSessions   Int     @default(0)
  absentSessions  Int     @default(0)
  pricePerSession Float   @default(0)
  subtotal        Float   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String?
  message   String
  type      String   // ABSENCE, CANCELLATION, INVOICE, GENERAL, ACTIVITY, SYSTEM
  read      Boolean  @default(false)
  link      String?  // Optional link to related entity
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id            String   @id @default(cuid())
  institutionId String
  type          String   // DAILY, MONTHLY
  data          String   // JSON string
  generatedAt   DateTime @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])
}

model Pricing {
  id            String @id @default(cuid())
  subjectId     String
  level         String
  pricePerSession Float @default(0)
  institutionId String

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}
